# =============================================
# VériNews — Configuration sécurisée
# =============================================

# ── API Anthropic ─────────────────────────────
ANTHROPIC_API_KEY

# ── Base de données ───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fakenews_app
DB_PASSWORD=root
DB_NAME=fakenews_db

# ── Flask ─────────────────────────────────────
FLASK_SECRET_KEY=REMPLACEZ_PAR_CLE_GENEREE_64_CHARS
FLASK_ENV=production
FLASK_DEBUG=0

# ── Sécurité ──────────────────────────────────
IP_HASH_SALT=REMPLACEZ_PAR_SALT_32_CHARS

# Rate limiting
RATE_LIMIT_ANALYSE=10
RATE_LIMIT_GLOBAL=60

# HTTPS (mettre True en production)
FORCE_HTTPS=False

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:5000
